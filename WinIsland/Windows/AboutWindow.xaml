<Window x:Class="WinIsland.Windows.AboutWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:ui="http://schemas.inkore.net/lib/ui/wpf/modern"
        xmlns:local="clr-namespace:WinIsland.Windows"
        mc:Ignorable="d"
        WindowStartupLocation="CenterScreen"
        ui:WindowHelper.UseModernWindowStyle="True"
        ui:TitleBar.Height="0"
        ResizeMode="NoResize"
        Title="AboutWindow" Height="423" Width="597">
    <Grid Background="Black">
        <Image Source="/Assets/wypher.jpg" Stretch="Uniform" Opacity="0.4" ClipToBounds="False" Margin="-12" x:Name="backgroundImage">
            <Image.Effect>
                <BlurEffect x:Name="blurEffect" Radius="24"/>
            </Image.Effect>
        </Image>
        <Grid MouseDown="Grid_MouseDown" MouseUp="Grid_MouseUp" Background="#00000011" x:Name="mainGrid">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                <Label Content="WinIsland" FontSize="30" FontWeight="Bold" Foreground="White" HorizontalContentAlignment="Center"/>
                <Label x:Name="versionLabel" Content="Version 0" FontSize="16" Foreground="White" HorizontalContentAlignment="Center"/>
                <Label Content="© 2026 WinIsland Contributors &amp; CRML Studios. All rights reserved." FontSize="12" Foreground="White" HorizontalContentAlignment="Center"/>
                <Label Content="Developed by Caramell DaxiRelta" FontSize="12" Margin="0,20,0,0" Foreground="White" HorizontalContentAlignment="Center"/>
                <Label Content="Hold Left click on the window to view background." FontSize="12" Margin="0,0,0,0" Foreground="White" HorizontalContentAlignment="Center" Opacity="0.6"/>
            </StackPanel>
        </Grid>
        <Grid x:Name="titleBar" Height="32" VerticalAlignment="Top" Background="#00000000" MouseDown="titleBar_MouseDown">
            <Grid.Resources>
                <Style x:Name="buttonStyle" TargetType="{x:Type Button}">
                    <Setter Property="Background" Value="Transparent"/>
                    <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="{x:Type Button}">
                                <Border RenderTransformOrigin="0.5,0.5" x:Name="ButtonGrid" Background="{TemplateBinding Background}" CornerRadius="5">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    <Border.RenderTransform>
                                        <ScaleTransform/>
                                    </Border.RenderTransform>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsPressed" Value="True">
                                        <Trigger.EnterActions>
                                            <BeginStoryboard>
                                                <Storyboard>
                                                    <DoubleAnimation Duration="0:0:0.1" Storyboard.TargetName="ButtonGrid" Storyboard.TargetProperty="(RenderTransform).(ScaleTransform.ScaleX)" To="0.85">
                                                        <DoubleAnimation.EasingFunction>
                                                            <BounceEase EasingMode="EaseInOut"/>
                                                        </DoubleAnimation.EasingFunction>
                                                    </DoubleAnimation>
                                                    <DoubleAnimation Duration="0:0:0.1" Storyboard.TargetName="ButtonGrid" Storyboard.TargetProperty="(RenderTransform).(ScaleTransform.ScaleY)" To="0.85">
                                                        <DoubleAnimation.EasingFunction>
                                                            <CubicEase EasingMode="EaseInOut"/>
                                                        </DoubleAnimation.EasingFunction>
                                                    </DoubleAnimation>
                                                </Storyboard>
                                            </BeginStoryboard>
                                        </Trigger.EnterActions>
                                        <Trigger.ExitActions>
                                            <BeginStoryboard>
                                                <Storyboard>
                                                    <DoubleAnimation Duration="0:0:0.05" Storyboard.TargetName="ButtonGrid" Storyboard.TargetProperty="(RenderTransform).(ScaleTransform.ScaleX)" To="1">
                                                        <DoubleAnimation.EasingFunction>
                                                            <CubicEase EasingMode="EaseInOut"/>
                                                        </DoubleAnimation.EasingFunction>
                                                    </DoubleAnimation>
                                                    <DoubleAnimation Duration="0:0:0.05" Storyboard.TargetName="ButtonGrid" Storyboard.TargetProperty="(RenderTransform).(ScaleTransform.ScaleY)" To="1">
                                                        <DoubleAnimation.EasingFunction>
                                                            <CubicEase EasingMode="EaseInOut"/>
                                                        </DoubleAnimation.EasingFunction>
                                                    </DoubleAnimation>
                                                </Storyboard>
                                            </BeginStoryboard>
                                        </Trigger.ExitActions>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                    <Style.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Background" Value="#33FFFFFF"/>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter Property="Background" Value="#22FFFFFF"/>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Foreground" Value="Gray"/>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="True">
                            <Setter Property="Foreground" Value="{DynamicResource {x:Static ui:ThemeKeys.DefaultTextForegroundThemeBrushKey}}"/>
                        </Trigger>
                    </Style.Triggers>
                </Style>
            </Grid.Resources>
            <StackPanel FlowDirection="RightToLeft" Orientation="Horizontal">
                <Button x:Name="closeButton" MouseLeave="closeButton_MouseLeave" MouseDown="closeButton_MouseDown" MouseEnter="closeButton_MouseEnter"  Margin="0,0,0,00" VerticalAlignment="Center" Width="42" Height="32" Content="&#xE8bb;" FontFamily="../Fonts/#Segoe Fluent Icons" Click="closeButton_Click"/>
                <Button x:Name="minimizeButton" Margin="0,0,0,00" VerticalAlignment="Center" Width="42" Height="32" Content="&#xe921;" FontFamily="../Fonts/#Segoe Fluent Icons" Click="minimizeButton_Click"/>
            </StackPanel>
        </Grid>
    </Grid>
</Window>
